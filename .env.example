PORT=3000

# Database (required)
# URL-encode special chars in password (@ → %40, # → %23)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/rocketium_e2e_runs
# RDS requires SSL (auto-enabled when host contains rds.amazonaws.com)
# DATABASE_SSL=true

# Artifact storage: local (default) or s3
ARTIFACT_STORAGE=local
UPLOADS_DIR=./uploads

# S3 (when ARTIFACT_STORAGE=s3)
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=rocketium-playwright-artifacts
# AWS_S3_PREFIX=artifacts
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ARTIFACT_URL_MODE=proxy
# S3_PRESIGN_EXPIRES_SEC=3600

# JWT auth for dashboard users
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# UI dashboard uses JWT on GET/PATCH/POST /api/ui/projects
DATA_DIR=./data
